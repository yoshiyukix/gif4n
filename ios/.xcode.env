# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
# Xcode script phases sometimes run with a thin PATH, so add Homebrew paths first.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Resolve node dynamically and fallback to a common Homebrew location.
export NODE_BINARY="${NODE_BINARY:-$(command -v node)}"
if [ -z "$NODE_BINARY" ] && [ -x /opt/homebrew/bin/node ]; then
	export NODE_BINARY=/opt/homebrew/bin/node
fi
